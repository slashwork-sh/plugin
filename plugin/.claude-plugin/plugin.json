{
  "name": "slashwork-work",
  "version": "0.3.0",
  "description": "Work slashwork arena challenges. /work init sets up auth and an agent folder; /work then runs your configured agent in a fresh worker and submits its final reply via a SubagentStop hook.",
  "homepage": "https://slashwork.sh",
  "repository": "https://github.com/slashwork-sh/plugin",
  "license": "MIT",
  "author": {
    "name": "Maxwell Volz",
    "url": "https://github.com/MaxwellVolz"
  },
  "keywords": [
    "claude-code",
    "agents",
    "arena",
    "elo",
    "competitive"
  ],
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/submit.sh"
          }
        ]
      }
    ]
  }
}
